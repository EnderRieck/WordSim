{
  "model_name": "msmarco-minilm-l6-multitask-lr-5e-6",
  "data_output_dir": "artifacts/data/multitask",
  "seed": 42,
  "training": {
    "learning_rate": 5e-6,
    "epochs": 3,
    "train_batch_size": 32,
    "eval_batch_size": 64,
    "max_length": 256,
    "warmup_ratio": 0.1,
    "base_model": "cross-encoder/ms-marco-MiniLM-L-6-v2"
  },
  "evaluation": {
    "report_dir": "artifacts/reports"
  },
  "datasets": [
    {
      "name": "lcqmc",
      "enabled": true,
      "type": "pairs",
      "path": "C-MTEB/LCQMC",
      "text1_column": "sentence1",
      "text2_column": "sentence2",
      "label_column": "score",
      "label_scale": 1.0,
      "train_examples": 120000,
      "validation_examples": 8000,
      "test_examples": 8000
    },
    {
      "name": "stsb_zh",
      "enabled": true,
      "type": "pairs",
      "path": "mteb/STSB",
      "text1_column": "sentence1",
      "text2_column": "sentence2",
      "label_column": "score",
      "label_scale": 5.0,
      "train_examples": 5231,
      "validation_examples": 1458,
      "test_examples": 1361
    },
    {
      "name": "pawsx_zh",
      "enabled": true,
      "type": "pairs",
      "path": "C-MTEB/PAWSX",
      "text1_column": "sentence1",
      "text2_column": "sentence2",
      "label_column": "score",
      "label_scale": 1.0,
      "train_examples": 40000,
      "validation_examples": 2000,
      "test_examples": 2000
    },
    {
      "name": "msmarco_en",
      "enabled": true,
      "type": "triplets",
      "path": "sentence-transformers/msmarco-msmarco-MiniLM-L6-v3",
      "config": "triplet-50",
      "query_column": "query",
      "positive_column": "positive",
      "negative_prefix": "negative_",
      "negatives_per_query": 1,
      "train_examples": 120000,
      "validation_examples": 8000,
      "test_examples": 8000
    }
  ]
}
